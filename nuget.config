<?xml version="1.0" encoding="utf-8"?>
<!--
  Isolates the DittoDotnetTools NuGet restore from the parent
  sdks/dotnet/nuget.config
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>

  <packageSourceMapping>
    <clear />
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
